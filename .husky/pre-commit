#!/bin/sh
# Pre-commit hook para ERP Universal
# Local: .husky/pre-commit

echo "🔍 Executando validações pré-commit..."

# Executar lint
echo "📝 Verificando ESLint..."
npm run lint
if [ $? -ne 0 ]; then
    echo "❌ ESLint falhou. Corrija os erros antes de commitar."
    exit 1
fi

# Executar TypeScript check
echo "📝 Verificando TypeScript..."
npm run check
if [ $? -ne 0 ]; then
    echo "❌ TypeScript falhou. Corrija os erros antes de commitar."
    exit 1
fi

echo "✅ Todas as validações passaram!"
